# =============================================================================
# CoPaw 项目环境变量配置
# 此文件在 CoPaw 启动时自动加载（runner.py → load_dotenv）
# 修改后重启 CoPaw 进程生效
# =============================================================================

# 合同模板库目录（match_by_file.py / local_template_api.py 读取）
TEMPLATE_DIR=/Users/jiangshengping/.copaw/contract_templates

# 本地模板检索 API 端口（local_template_api.py 监听）
TEMPLATE_PORT=9000
TEMPLATE_API_BASE=http://localhost:9000

# CoPaw 服务地址（skill 脚本调用 push / download 等接口时使用）
COPAW_API_BASE=http://127.0.0.1:8088

# 生成的 Word 合同文件存放目录
CONTRACT_STORAGE_DIR=/Users/jiangshengping/.copaw/contracts

# 执行日志 SQLite 数据库路径
AGENT_LOG_DB=/Users/jiangshengping/.copaw/agent_logs.db

# Redis 消息队列（skill 执行结果推送）
REDIS_HOST=10.156.196.158
REDIS_PORT=6379
REDIS_PASSWORD=redis_2Yzs26
